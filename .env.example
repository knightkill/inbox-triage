# Copy to .env for local runs (scripts/*). NEVER commit .env (HARP-2.2).
# In Azure these come from Key Vault via Managed Identity instead (M5).

# --- Azure OpenAI (reuse your trainGemma resource or a fresh one) ---
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure Document Intelligence (M4) ---
AZURE_DOCINTEL_ENDPOINT=https://YOUR-DOCINTEL.cognitiveservices.azure.com/
AZURE_DOCINTEL_KEY=

# --- Azure Storage (state + attachment staging; M3/M4) ---
AZURE_STORAGE_CONNECTION_STRING=
TRIAGE_STATE_CONTAINER=triage-state

# --- Gmail (M2) ---
# OAuth client + token live in credentials.json / token.json (gitignored).
# This just names the account label you're triaging.
GMAIL_ACCOUNT=me

# --- Safety (M3) ---
# Default TRUE: never mutate Gmail unless explicitly disabled.
TRIAGE_DRY_RUN=true
TRIAGE_DAILY_LIMIT=500
